{
	"name": "challenge",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun --bun --cwd ./apps/web dev",
		"build": "cd ./apps/web && bun run build",
		"start": "cd ./apps/web && bun start",
		"verify": "bun --bun --filter=\"*\" verify --",
		"typecheck": "bun --bun --filter=\"@repo/locales\" run build && bun --bun --filter=\"*\" typecheck",
		"test": "vitest",
		"db": "cd packages/domains && bun --bun db",
		"storybook": "cd packages/domains && bun storybook",
		"storybook:build": "cd packages/domains && bun storybook:build",
		"storybook:static": "cd packages/domains && bun storybook:static"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@testing-library/react": "^16.3.0",
		"@typescript/native-preview": "^7.0.0-dev.20260306.1",
		"jsdom": "^28.1.0",
		"vitest": "^4.0.18",
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"typescript": "catalog:general"
	},
	"packageManager": "bun@1.3.10",
	"workspaces": {
		"packages": [
			"packages/*",
			"apps/*"
		],
		"catalogs": {
			"general": {
				"vite": "v8.0.0-beta.15",
				"typescript": "5.9.3",
				"tailwindcss": "^4.2.1",
				"@trpc/server": "^11.12.0",
				"zod": "^4.3.6",
				"@tanstack/react-router": "^1.166.2",
				"@tanstack/react-query": "^5.90.21",
				"@tanstack/react-start": "^1.166.2"
			},
			"react": {
				"react": "^19.2.4",
				"motion": "^12.35.0",
				"@types/react": "^19.2.14",
				"lucide-react": "0.577.0",
				"@types/react-dom": "^19.2.3",
				"react-dom": "^19.2.4"
			}
		}
	}
}
