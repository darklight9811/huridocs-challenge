{
	"name": "@repo/ds",
	"private": true,
	"type": "module",
	"scripts": {
		"verify": "biome check --error-on-warnings ./src",
		"typecheck": "tsgo --noEmit",
		"test": "vitest",
		"test:node": "vitest --run --config ../../vitest.node.config.ts",
		"test:dom": "vitest --run --config ../../scripts/src/vitest.dom.config.ts --passWithNoTests",
		"component": "bun --bun shadcn add"
	},
	"overrides": {
		"vite": "8.0.0-beta.0"
	},
	"exports": {
		"./ui/*": "./src/ui/*.tsx",
		"./lib/*": "./src/lib/*.ts",
		"./hooks/*": "./src/hooks/*.tsx",
		"./icons/*": "./src/icons/*.tsx",
		"./3d/*": "./src/3d/*.tsx",
		"./types/*": "./src/types/*.ts",
		"./style": "./src/style.css"
	},
	"devDependencies": {
		"@types/react": "catalog:react",
		"shadcn": "^4.0.6",
		"tailwindcss": "catalog:general"
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@tanstack/react-form": "^1.28.5",
		"@tanstack/react-router": "catalog:general",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "catalog:react",
		"react": "catalog:react",
		"react-dom": "catalog:react",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zod": "catalog:general"
	}
}
